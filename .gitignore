/build-tests/

# Local native test builds (see native-test-build-recipe; faces variant for the
# env-gated SCRFD end-to-end tests)
/build-tests-faces/

# Rust / native build dirs
target/

# Backup files
*.bak

# OS / editor cruft
.DS_Store
*~

# Flutter/Dart artifacts at any depth (pablo/.gitignore also covers these)
**/.dart_tool/
**/build/

# Local image datasets — multi-GB corpora, never commit (e.g. Flickr30k)
/flickr30k_images/
/datasets/

# Sibling git worktrees (feature branches checked out in-tree)
/Pablo-dedup/
/Pablo-faces/

# Claude Design handoff bundle (reference only, not app code)
/pablo-cool/

# Stage 9 semantic-search: local ML venv + exported model artifacts (large, not committed)
.venv-semantic/
build-ort/
build-werror/
