# Root build artifacts (CMake/native output) — keep source, drop build output
/build/

# Rust / native build dirs
target/

# Backup files
*.bak

# OS / editor cruft
.DS_Store
*~

# Flutter/Dart artifacts at any depth (pablo/.gitignore also covers these)
**/.dart_tool/
**/build/

# Local image datasets — multi-GB corpora, never commit (e.g. Flickr30k)
/flickr30k_images/
/datasets/

# Generated face database (eval/ingest/build_face_db.py) — crops of real,
# named people + a manifest with names and absolute photo paths. PII: NEVER
# commit. Anchored at any depth so it's covered regardless of --out / CWD.
**/faces_db/
**/crops/
**/manifest.csv
/.testdata/
